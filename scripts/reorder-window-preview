#!/usr/bin/env bash

set -euo pipefail

if [[ "${1:-}" == "--preview" ]]; then
  current_index="$2"
  target_index="$3"

  tmux list-windows -F '#{window_index}	#{window_name}' |
    awk -F '\t' -v current="$current_index" -v target="$target_index" '
      {
        indexes[NR] = $1
        names[$1] = $2

        if ($1 == current) {
          current_name = $2
        }
      }

      END {
        print "Resulting order:"
        print ""

        for (i = 1; i <= NR; i++) {
          if (indexes[i] == current) {
            current_position = i
          }

          if (indexes[i] == target) {
            target_position = i
          }
        }

        for (i = 1; i <= NR; i++) {
          window_index = indexes[i]
          new_names[window_index] = names[window_index]

          if (current_position < target_position) {
            if (i >= current_position && i < target_position) {
              new_names[window_index] = names[indexes[i + 1]]
            } else if (i == target_position) {
              new_names[window_index] = current_name
            }
          } else if (current_position > target_position) {
            if (i == target_position) {
              new_names[window_index] = current_name
            } else if (i > target_position && i <= current_position) {
              new_names[window_index] = names[indexes[i - 1]]
            }
          }
        }

        for (i = 1; i <= NR; i++) {
          window_index = indexes[i]
          marker = window_index == target ? "⇢" : " "
          current_marker = new_names[window_index] == current_name ? "  ← current" : ""
          printf "%s %s  %s%s\n", marker, window_index, new_names[window_index], current_marker
        }
      }
    '

  exit 0
fi

current_index="$(tmux display-message -p '#{window_index}')"

selected="$(
  tmux list-windows -F '#{window_index}	#{window_name}	#{?window_active,active,}' |
    fzf \
      --ansi \
      --border=rounded \
      --border-label=' GRID REORDER ' \
      --color='bg:#05070d,bg+:#003b46,fg:#c5c8c6,fg+:#00ffff,hl:#00e5ff,hl+:#00ffff' \
      --color='border:#00e5ff,header:#00e5ff,info:#5c6370,label:#00ffff' \
      --color='marker:#ffcc00,pointer:#00ffff,prompt:#00e5ff,spinner:#00ffff' \
      --layout=reverse \
      --no-sort \
      --delimiter='\t' \
      --with-nth=1,2,3 \
      --header='Move current window to selected position' \
      --preview="$0 --preview $current_index {1}" \
      --preview-label=' RESULTING ORDER ' \
      --preview-window='right:55%:wrap:border-rounded'
)"

target_index="${selected%%$'\t'*}"

if [[ -z "$target_index" || "$target_index" == "$current_index" ]]; then
  exit 0
fi

mapfile -t window_indexes < <(tmux list-windows -F '#{window_index}')
current_position=-1
target_position=-1

for position in "${!window_indexes[@]}"; do
  if [[ "${window_indexes[$position]}" == "$current_index" ]]; then
    current_position="$position"
  fi

  if [[ "${window_indexes[$position]}" == "$target_index" ]]; then
    target_position="$position"
  fi
done

if (( current_position < 0 || target_position < 0 )); then
  exit 1
fi

if (( target_position > current_position )); then
  for ((position = current_position; position < target_position; position++)); do
    tmux swap-window -d \
      -s ":${window_indexes[$position]}" \
      -t ":${window_indexes[$((position + 1))]}"
  done
else
  for ((position = current_position; position > target_position; position--)); do
    tmux swap-window -d \
      -s ":${window_indexes[$position]}" \
      -t ":${window_indexes[$((position - 1))]}"
  done
fi

tmux select-window -t ":$target_index"
tmux display-message "Moved window $current_index → $target_index"
